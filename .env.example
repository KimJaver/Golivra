# Origine du backend (sans suffixe /api ; les routes /api/... sont ajoutées par le client).
#
# Production (Render) :
EXPO_PUBLIC_API_BASE_URL=https://golivraback.onrender.com
#
# Développement local (copier dans .env.local) :
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000 # émulateur Android
# EXPO_PUBLIC_API_BASE_URL=http://IP_DE_TON_PC:3000 # appareil physique
#
# Web : ajoute l'origine exacte de ton front dans CORS_ORIGINS côté Render (ex. https://xxx.exp.direct).
#
# HTTP local (APK dev / émulateur uniquement) :
# EXPO_PUBLIC_ALLOW_HTTP=1

# ============================================
# SUPABASE (Temps réel - Realtime)
# ============================================
# Récupère ces infos dans Project Settings > API sur supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici

# ============================================
# SENTRY (suivi des crashs en production)
# ============================================
# Projet : org golivra / react-native (région EU de.sentry.io)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@o4511438793605120.ingest.de.sentry.io/4511438796357712
SENTRY_ORG=golivra
SENTRY_PROJECT=react-native
# Build EAS uniquement : token Sentry > Settings > Auth Tokens (upload source maps)
# SENTRY_AUTH_TOKEN=ton-token-secret
